# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Optional OpenRouter API Key for SSE streaming models
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# REDIS_URL: Redis connection for BullMQ 24/7 task scheduler
REDIS_URL="redis://localhost:6379"

# NOTION_API_KEY & NOTION_DATABASE_ID: For Notion content planner integration
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

